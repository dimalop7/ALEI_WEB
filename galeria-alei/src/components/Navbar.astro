---
// Navbar.astro
const { pathname } = Astro.url;
---

<nav class="fixed top-0 w-full z-50 bg-white transition-colors duration-500">
    <div class="flex justify-center items-center w-full px-4 md:px-8 py-6 max-w-screen-2xl mx-auto">
        <div class="flex space-x-4 sm:space-x-8 md:space-x-12 font-['Newsreader'] tracking-[0.1em] md:tracking-widest uppercase text-[10px] sm:text-xs md:text-sm">
            <a class={`nav-link transition-all ${pathname === '/' ? 'active text-[#2d3435] border-b border-[#2d3435] pb-1' : 'text-[#5f5e5e] hover:text-[#2d3435] hover:opacity-70'}`} href="/">Home</a>
            <a class={`nav-link transition-all ${pathname.includes('/series') ? 'active text-[#2d3435] border-b border-[#2d3435] pb-1' : 'text-[#5f5e5e] hover:text-[#2d3435] hover:opacity-70'}`} href="/series">Series</a>
            <a class={`nav-link transition-all ${pathname.includes('/colaboraciones') ? 'active text-[#2d3435] border-b border-[#2d3435] pb-1' : 'text-[#5f5e5e] hover:text-[#2d3435] hover:opacity-70'}`} href="/colaboraciones">Colaboraciones</a>
            <a class={`nav-link transition-all ${pathname.includes('/catalogo') ? 'active text-[#2d3435] border-b border-[#2d3435] pb-1' : 'text-[#5f5e5e] hover:text-[#2d3435] hover:opacity-70'}`} href="/catalogo">Catálogo</a>
        </div>
    </div>
</nav>