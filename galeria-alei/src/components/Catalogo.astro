---
// Catalogo.astro
const cuadros = [
    { id: 'cuadro-1', image: '/img-catalog/f1.png', title: 'Cuadro 1' },
    { id: 'cuadro-2', image: '/img-catalog/f2.png', title: 'Cuadro 2' },
    { id: 'cuadro-3', image: '/img-catalog/f3.png', title: 'Cuadro 3' },
];
---

<section class="pt-8 pb-10" id="catalog">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6 mb-10">
        {cuadros.map((cuadro) => (
            <a href={`/catalogo/${cuadro.id}`} class="group cursor-pointer block">
                <div class="aspect-square bg-surface-container-low overflow-hidden relative">
                    <img alt={cuadro.title}
                         class="w-full h-full object-cover transition-opacity duration-500 group-hover:opacity-80"
                         src={cuadro.image} />
                </div>
            </a>
        ))}
    </div>
    <div class="flex justify-center mt-12">
        <a href="/catalogo"
            class="font-label text-xs uppercase tracking-[0.3em] border-b border-on-surface/50 pb-2 hover:border-on-surface hover:text-on-surface/80 transition-all">
            Ver Catálogo Completo
        </a>
    </div>
</section>