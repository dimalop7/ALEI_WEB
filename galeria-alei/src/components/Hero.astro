---
// Hero.astro
---

<header class="min-h-screen pt-48 pb-24 flex flex-col justify-center relative">
    <div class="grid lg:grid-cols-12 gap-12 items-center z-10 w-full">
        <div class="lg:col-span-6 flex flex-col items-start pr-8">
            <h1
                class="font-headline text-[clamp(4rem,18vw,14rem)] leading-[0.8] font-light tracking-tighter mb-12 text-on-surface">
                Alei
            </h1>
            <p class="font-body text-xl md:text-2xl font-light tracking-wide text-secondary max-w-xl mb-16">
                Arquitecto, Artista y Modelo. <br />
            </p>
            <div class="flex items-center gap-12">
                <a class="font-label text-sm uppercase tracking-[0.2em] border-b border-on-surface/30 pb-2 hover:border-on-surface transition-all duration-500 group flex items-center gap-4"
                    href="https://instagram.com/aleidraws">
                    Instagram
                    <span
                        class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_outward</span>
                </a>
            </div>
        </div>
        <div class="lg:col-span-6 flex justify-end w-full">
            <div
                class="w-full max-w-md aspect-[3/4] overflow-hidden bg-surface-container-low grayscale hover:grayscale-0 transition-all duration-700 shadow-2xl">
                <img src="/img-hero/f1.png" alt="Hero Portrait" class="w-full h-full object-cover"
                    onerror="this.src='https://placehold.co/600x800/e5e2e1/5f5e5e?text=Placeholder'" />
            </div>
        </div>
    </div>
    <!-- Ambient Texture Background -->
    <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] opacity-10 pointer-events-none -z-10">
        <div
            class="w-full h-full bg-gradient-to-tr from-surface-container-high via-surface to-surface-container-low">
        </div>
    </div>
</header>