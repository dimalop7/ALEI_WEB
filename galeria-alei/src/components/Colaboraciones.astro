<!-- Collab 4: Inverted (Text Left, Carousel Right) -->
<section class="py-24">
    <div class="grid md:grid-cols-12 gap-12 items-center">
        <!-- Text Area (Left) -->
        <div class="md:col-span-6 lg:col-span-7 xl:col-span-7 3xl:col-span-5 flex flex-col items-center md:items-start text-center md:text-left gap-8 px-6 md:px-0 md:pr-8 order-2 md:order-1">
            <div class="flex flex-col gap-2 items-center md:items-start">
                <h3 class="font-headline text-4xl md:text-5xl leading-tight font-light text-on-surface italic">Alei X ZaraKids</h3>
            </div>
            <p class="font-body text-lg text-secondary leading-relaxed text-center md:text-justify">
                Colección que fusiona la estética de ZaraKids con la visión artística de Alei, creando una colección para niños a través de un lente artístico contemporáneo.
            </p>
        </div>

        <!-- Carousel Area (Right) -->
        <div class="md:col-span-6 lg:col-span-5 xl:col-span-5 3xl:col-span-7 w-[90%] md:w-full mx-auto bg-surface-container-low shadow-xl group relative carousel-container order-1 md:order-2">
            <div class="relative overflow-hidden aspect-[4/5] max-h-[70vh] md:max-h-none">
                <div class="carousel-track h-full scroll-smooth">
                    <div class="carousel-item">
                        <img alt="Item 1" class="w-full h-full object-cover transition-all duration-700" src="/img-col-car-4/f1.png" />
                    </div>
                    <div class="carousel-item">
                        <img alt="Item 2" class="w-full h-full object-cover transition-all duration-700" src="/img-col-car-4/f2.png" />
                    </div>
                    <div class="carousel-item">
                        <img alt="Item 3" class="w-full h-full object-cover transition-all duration-700" src="/img-col-car-4/f3.png" />
                    </div>
                    <div class="carousel-item">
                        <img alt="Item 4" class="w-full h-full object-cover transition-all duration-700" src="/img-col-car-4/f4.png" />
                    </div>
                </div>
                <!-- Controls -->
                <button class="absolute z-10 top-1/2 left-6 -translate-y-1/2 w-12 h-12 flex items-center justify-center bg-white/80 hover:scale-105 shadow-md rounded-full text-black/80 hover:text-black backdrop-blur-md transition-all duration-300 opacity-0 group-hover:opacity-100 carousel-prev" aria-label="Anterior">
                    <span class="material-symbols-outlined text-lg">arrow_back_ios_new</span>
                </button>
                <button class="absolute z-10 top-1/2 right-6 -translate-y-1/2 w-12 h-12 flex items-center justify-center bg-white/80 hover:scale-105 shadow-md rounded-full text-black/80 hover:text-black backdrop-blur-md transition-all duration-300 opacity-0 group-hover:opacity-100 carousel-next" aria-label="Siguiente">
                    <span class="material-symbols-outlined text-lg">arrow_forward_ios</span>
                </button>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll('.carousel-container').forEach((container: any) => {
            const track = container.querySelector('.carousel-track');
            const items = container.querySelectorAll('.carousel-item');
            const prevBtn = container.querySelector('.carousel-prev');
            const nextBtn = container.querySelector('.carousel-next');

            if (!track || !items.length) return;

            let currentIndex = 0;
            let isAnimating = false;

            const updateCarousel = () => {
                const offset = currentIndex * 100;
                track.style.transform = `translateX(-${offset}%)`;

                // Update button visibility
                if (prevBtn) {
                    prevBtn.style.display = currentIndex === 0 ? 'none' : 'flex';
                }
                if (nextBtn) {
                    nextBtn.style.display = currentIndex === items.length - 1 ? 'none' : 'flex';
                }
            };

            if (nextBtn) {
                nextBtn.addEventListener('click', () => {
                    if (isAnimating || currentIndex === items.length - 1) return;
                    isAnimating = true;
                    currentIndex++;
                    updateCarousel();
                    setTimeout(() => { isAnimating = false; }, 450);
                });
            }

            if (prevBtn) {
                prevBtn.addEventListener('click', () => {
                    if (isAnimating || currentIndex === 0) return;
                    isAnimating = true;
                    currentIndex--;
                    updateCarousel();
                    setTimeout(() => { isAnimating = false; }, 450);
                });
            }

            // Inicializar el estado
            updateCarousel();
        });
    });
</script>